<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OAS | Agent Configuration</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary: #075e54;
            --primary-light: #128c7e;
            --whatsapp-green: #25d366;
            --danger: #ef4444;
            --bg: #f8fafc;
            --white: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --sidebar-width: 260px;
        }

        * {
            box-sizing: border-box;
            transition: all 0.2s ease-in-out;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--primary);
            color: white;
            position: fixed;
            height: 100vh;
            padding: 24px;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-brand {
            font-size: 1.25rem;
            font-weight: 800;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white;
        }

        .nav-menu {
            list-style: none;
            padding: 0;
            margin: 0;
            flex-grow: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 6px;
            font-weight: 600;
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .nav-item.active {
            background: var(--whatsapp-green);
            color: white;
            box-shadow: 0 10px 15px -3px rgba(37, 211, 102, 0.2);
        }

        .logout-btn {
            margin-top: auto;
            color: #fecaca;
            border: 1px solid rgba(254, 202, 202, 0.2);
            justify-content: center;
        }

        /* --- MAIN CONTENT --- */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            max-width: 1400px;
        }

        .settings-header {
            margin-bottom: 32px;
        }

        .settings-header h1 {
            font-weight: 800;
            font-size: 1.85rem;
            color: var(--text-main);
            margin: 0;
        }

        .settings-container {
            display: grid;
            grid-template-columns: 1fr 450px;
            gap: 32px;
            align-items: start;
        }

        /* --- MANAGEMENT CARD --- */
        .management-card {
            background: var(--white);
            border-radius: 24px;
            padding: 32px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .section-label {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 1.1rem;
            margin-bottom: 24px;
            color: var(--text-main);
        }

        .input-group {
            margin-bottom: 24px;
        }

        .input-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        /* Styled Select Box */
        .select-wrapper {
            position: relative;
            background: #f1f5f9;
            border-radius: 12px;
            border: 2px solid transparent;
            padding-right: 15px;
        }

        .select-wrapper select {
            width: 100%;
            padding: 14px 20px;
            border: none;
            background: transparent;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-main);
            appearance: none;
            outline: none;
            cursor: pointer;
        }

        /* Ensure the wrapper matches the select-wrapper exactly */
        .input-wrapper {
            background: #f1f5f9;
            border-radius: 12px;
            border: 2px solid transparent;
            display: flex;
            align-items: center;
            padding: 0 20px;
            /* Padding on the sides, height controlled by input padding */
            transition: all 0.2s ease;
        }

        /* Style the icon to match the muted look of your chevron */
        .input-wrapper i {
            color: var(--text-muted);
            margin-right: 12px;
            font-size: 1rem;
        }

        /* Make the input invisible so the wrapper looks like the field */
        .input-wrapper input {
            width: 100%;
            padding: 14px 0;
            /* Matches the 14px padding on your select */
            border: none;
            background: transparent;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-main);
            outline: none;
        }

        /* Focus states for consistency */
        .input-wrapper:focus-within,
        .select-wrapper:focus-within {
            background: white;
            border-color: var(--whatsapp-green);
            box-shadow: 0 0 0 4px rgba(37, 211, 102, 0.1);
        }

        /* Optional: Remove number arrows for a cleaner look */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* --- WATCHLIST CARD --- */
        .active-list-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 24px;
            border: 1px solid var(--border);
        }

        .team-badge {
            background: #f0fdf4;
            color: var(--primary-light);
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 15px;
            display: inline-block;
        }

        .agent-chip {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            background: #f8fafc;
            border-radius: 16px;
            margin-bottom: 12px;
            border: 1px solid var(--border);
        }

        .agent-info h4 {
            margin: 0;
            font-size: 0.95rem;
            color: var(--text-main);
        }

        .agent-info small {
            color: var(--text-muted);
            font-size: 0.8rem;
            display: block;
        }

        .agent-info span {
            font-size: 0.75rem;
            color: var(--whatsapp-green);
            font-weight: 700;
            display: block;
            margin-top: 4px;
        }

        .del-btn-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: none;
            background: #fee2e2;
            color: var(--danger);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .del-btn-circle:hover {
            background: var(--danger);
            color: white;
        }

        .btn-main {
            width: 100%;
            padding: 16px;
            border-radius: 12px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: var(--primary);
            color: white;
        }

        .btn-main:hover {
            background: var(--primary-light);
            transform: translateY(-1px);
        }
    </style>
</head>

<body>

    <nav class="sidebar">
        <a href="#" class="sidebar-brand">
            <i class="fab fa-whatsapp" style="font-size: 1.8rem; color: var(--whatsapp-green);"></i>
            <span>OAS Support</span>
        </a>

        <div class="nav-menu">
            <a href="/dashboard?role=<%= encodeURIComponent(role) %>&team=<%= encodeURIComponent(team) %>&groups=<%= encodeURIComponent(JSON.stringify(groups)) %>&numbers=<%= encodeURIComponent(numbers.join(',')) %>&names=<%= encodeURIComponent(names.join(',')) %>"
                class="nav-item">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
            </a>
            <a href="#" class="nav-item active">
                <i class="fas fa-sliders-h"></i> <span>Configuration</span>
            </a>
        </div>

        <a href="/logout_bot" class="nav-item logout-btn">
            <i class="fas fa-power-off"></i> <span>Logout</span>
        </a>
    </nav>

    <main class="main-content">
        <div class="settings-header">
            <h1>Configuration</h1>
            <p style="color: var(--text-muted); margin-top: 6px;">Manage active monitoring for <strong>
                    <%= team %>
                </strong>.</p>
        </div>

        <div class="settings-container">
            <div class="management-card">
                <div class="section-label">
                    <i class="fas fa-user-plus" style="color: var(--primary-light);"></i>
                    Add Agent to Watchlist
                </div>

                <div class="input-group">
                    <label>Select Team Member</label>
                    <div class="select-wrapper">
                        <select id="agent_selector">
                            <option value="" disabled selected>Choose a member from <%= team %>
                            </option>
                            <% for(let i=0; i < numbers.length; i++) { %>
                                <option value="<%= numbers[i] %>" data-name="<%= names[i] %>" data-team="<%= team %>"
                                    data-groups="<%= encodeURIComponent(JSON.stringify(groups)) %>">
                                    <%= names[i] %> (<%= numbers[i] %>)
                                </option>
                                <% } %>
                        </select>
                        <i class="fas fa-chevron-down"
                            style="position:absolute; right:15px; top:50%; transform:translateY(-50%); pointer-events:none; color: var(--text-muted);"></i>
                    </div>
                </div>

                <div class="input-group">
                    <label>Alert Interval (Minute(s))</label>
                    <div class="input-wrapper">
                        <i class="far fa-clock"></i>
                        <input type="number" id="timer_input" placeholder="e.g. 5" value="1">
                    </div>
                </div>

                <button class="btn-main" onclick="sendData()">
                    Start Monitoring <i class="fas fa-plus"></i>
                </button>
            </div>

            <div class="active-list-card">
                <div class="team-badge">Team: <%= team %>
                </div>
                <div class="section-label" style="font-size: 1rem;">
                    <i class="fas fa-shield-check" style="color: var(--whatsapp-green);"></i>
                    Active Watchlist
                </div>

                <div id="numberList" style="margin-top: 20px;">
                    <% if(not_num.length===0) { %>
                        <div
                            style="text-align:center; padding: 40px 20px; border: 2px dashed var(--border); border-radius: 20px;">
                            <i class="fas fa-user-slash"
                                style="font-size: 1.5rem; color: var(--border); margin-bottom: 12px; display: block;"></i>
                            <span style="color: var(--text-muted); font-size: 0.85rem;">No active monitoring
                                sessions.</span>
                        </div>
                        <% } %>

                            <% not_num.forEach(n=> { %>
                                <div class="agent-chip">
                                    <div class="agent-info">
                                        <h4>
                                            <%= n.name || 'Unknown Agent' %>
                                        </h4>
                                        <small>+<%= n.num %></small>
                                        <span><i class="fas fa-stopwatch"></i>
                                            <%= ((n.time_to_notify)/1000)/60 %> min threshold
                                        </span>
                                    </div>
                                    <button class="del-btn-circle" onclick="quickDelete('<%= n.num %>')"
                                        title="Stop Monitoring">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                                <% }) %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function sendData() {
            const selector = document.getElementById('agent_selector');
            const num = selector.value;
            const name = selector.options[selector.selectedIndex].getAttribute('data-name');
            const team = selector.options[selector.selectedIndex].getAttribute('data-team');
            const groups = selector.options[selector.selectedIndex].getAttribute('data-groups');


            const time = document.getElementById('timer_input').value;

            if (!num || !time) {
                Swal.fire({ icon: 'error', title: 'Selection Required', text: 'Please pick a member and set a time.' });
                return;
            }

            Swal.fire({ title: 'Configuring...', didOpen: () => Swal.showLoading() });

            try {
                const res = await fetch(`/set-numbers`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        New_number: num,
                        New_time: time,
                        name: name,
                        team: team,
                        groups: groups
                    })
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Agent Added', showConfirmButton: false, timer: 1000 })
                        .then(() => location.reload());
                }
            } catch (err) {
                Swal.fire('Error', 'Update failed', 'error');
            }
        }

        async function quickDelete(val) {
            const result = await Swal.fire({
                title: 'Stop Monitoring?',
                text: "Inactivity alerts will no longer be sent for this agent.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Yes, stop'
            });

            if (result.isConfirmed) {
                const res = await fetch(`/del-numbers`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ del_number: val })
                });
                const data = await res.json();
                if (data.success) location.reload();
            }
        }
    </script>
</body>

</html>