<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Team Auto-Registration | <%= team.team_name %>
    </title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #075e54;
            --whatsapp-green: #25d366;
            --bg: #f0f2f5;
            --white: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 700px;
            margin-top: 40px;
        }

        .status-card {
            background: var(--white);
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            margin: 0;
            color: var(--primary);
            font-size: 1.8rem;
        }

        .header p {
            color: var(--text-muted);
            margin-top: 8px;
        }

        .agent-list {
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #edf2f7;
        }

        .agent-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            background: white;
            border-bottom: 1px solid #edf2f7;
            transition: background 0.2s;
        }

        .agent-row:last-child {
            border-bottom: none;
        }

        .agent-info strong {
            display: block;
            font-size: 1rem;
            color: var(--text-main);
        }

        .agent-info small {
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 500;
        }

        /* Status Pills */
        .status-pill {
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .pending {
            background: #f1f5f9;
            color: #94a3b8;
        }

        .success {
            background: #dcf8c6;
            color: #15803d;
        }

        .exists {
            background: #e0f2fe;
            color: #0369a1;
        }

        .error {
            background: #fee2e2;
            color: #b91c1c;
        }

        /* Loader */
        .loader {
            border: 2px solid #f3f3f3;
            border-top: 2px solid var(--whatsapp-green);
            border-radius: 50%;
            width: 18px;
            height: 18px;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .btn-action {
            width: 100%;
            background: var(--primary);
            color: white;
            border: none;
            padding: 18px;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 30px;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(7, 94, 84, 0.2);
        }

        .btn-action:hover:not(:disabled) {
            background: #054a42;
            transform: translateY(-2px);
        }

        .btn-action:disabled {
            background: #cbd5e1;
            cursor: not-allowed;
            box-shadow: none;
        }
    </style>
</head>

<body>

    <div id="agent-data-store" data-names='<%- JSON.stringify(agent_name) %>'
        data-nums='<%- JSON.stringify(agent_num) %>' data-roles='<%- JSON.stringify(agent_role) %>' data-team_name='<%- JSON.stringify(teamName) %>'
        data-groups ='<%- JSON.stringify(grps) %>'
     
        style="display: none;">
    </div>

    <div class="container">
        <div class="status-card">
            <div class="header">
                <div
                    style="background: var(--light-green); color: var(--primary); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; font-size: 1.5rem;">
                    <i class="fas fa-users-cog"></i>
                </div>
                <h1>Auto-Registration</h1>
                <p>Syncing agents for <b>
                        <%= team.team_name %>
                    </b></p>
            </div>

            <div class="agent-list">
                <% agent_name.forEach((name, index)=> { %>
                    <div class="agent-row">
                        <div class="agent-info">
                            <strong>
                                <%= name %>
                            </strong>
                            <small>
                                <%= agent_num[index] %> • <%= agent_role[index].toUpperCase() %>
                            </small>
                        </div>
                        <div id="status-<%= index %>">
                            <span class="status-pill pending">Ready</span>
                        </div>
                    </div>
                    <% }) %>
            </div>

            <button id="start-btn" class="btn-action" onclick="runRegistration()">
                <i class="fas fa-play" style="margin-right: 8px;"></i> Begin Sync Process
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        function generateStrongPassword(length = 12) {
            const upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            const lower = "abcdefghijklmnopqrstuvwxyz";
            const numbers = "0123456789";
            const symbols = "!@#$%^&*()_+";

            const allChars = upper + lower + numbers + symbols;

            let password = "";

            for (let i = 0; i < length; i++) {
                password += allChars[Math.floor(Math.random() * allChars.length)];
            }

            return password;
        }


        async function runRegistration() {
            // 1. Fetch data safely from the DOM
            const store = document.getElementById('agent-data-store');
            const names = JSON.parse(store.getAttribute('data-names') || '[]');
            const nums = JSON.parse(store.getAttribute('data-nums') || '[]');
            const roles = JSON.parse(store.getAttribute('data-roles') || '[]');
            const teamName= JSON.parse(store.getAttribute('data-team_name') || '[]');
            const groups= JSON.parse(store.getAttribute('data-groups') || '[]');


            const btn = document.getElementById('start-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Processing Agents...';

            // 2. Loop through agents one by one
            for (let i = 0; i < names.length; i++) {
                const statusDiv = document.getElementById(`status-${i}`);

                // Set loading state
                statusDiv.innerHTML = '<div class="loader"></div>';

                try {
                    const response = await fetch('/register_user', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            username: names[i],
                            number: nums[i],
                            password: generateStrongPassword(12), // Standard default password
                            role: roles[i],
                            numbers:nums,
                            team_name:teamName,
                            groups:groups,
                            names:names
                        })
                    });

                    const result = await response.json();

                    // 3. Logic to handle "Already Registered" check
                    if (result.success) {
                        statusDiv.innerHTML = '<span class="status-pill success"><i class="fas fa-check"></i> Done</span>';

                        btn.innerHTML = '<i class="fas fa-check-circle"></i> Process Complete';
                        // Swal.fire({
                        //     title: 'Sync Successful',
                        //     text: 'All agents have been processed.',
                        //     icon: 'success',
                        //     confirmButtonColor: '#075e54'
                        // });
                    } else if (result.message && result.message.toLowerCase().includes('already')) {
                        statusDiv.innerHTML = '<span class="status-pill exists">Already Registered</span>';

                        btn.innerHTML = '<i class="fas fa-check-circle"></i> Process Complete';

                    } else {
                        statusDiv.innerHTML = '<span class="status-pill error">Failed</span>';
                    }

                } catch (err) {
                    console.error(err);
                    statusDiv.innerHTML = '<span class="status-pill error">Error</span>';
                }

                // Optional: small delay to make the UI feel "natural"
                await new Promise(resolve => setTimeout(resolve, 300));
            }

            // Finalize UI

        }
    </script>

</body>

</html>