<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agent Access | Secure Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --whatsapp-green: #25d366;
            --dark-green: #075e54;
            --primary-gradient: linear-gradient(135deg, #075e54 0%, #128c7e 100%);
            --bg: #f8fafc;
            --white: #ffffff;
            --border: #e2e8f0;
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        * { box-sizing: border-box; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            background-image: radial-gradient(circle at 2px 2px, #e2e8f0 1px, transparent 0);
            background-size: 40px 40px;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .auth-card {
            background: var(--white);
            width: 100%;
            max-width: 440px;
            padding: 48px;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--white);
        }

        .brand-header { text-align: center; margin-bottom: 32px; }

        .logo-circle {
            width: 64px; height: 64px;
            background: var(--primary-gradient);
            color: white;
            border-radius: 20px;
            display: flex; justify-content: center; align-items: center;
            font-size: 1.5rem;
            margin: 0 auto 20px;
            box-shadow: 0 10px 15px -3px rgba(7, 94, 84, 0.3);
        }

        h1 { color: var(--text-main); font-size: 1.75rem; font-weight: 800; margin: 0; letter-spacing: -0.025em; }
        p { color: var(--text-muted); font-size: 0.95rem; margin: 8px 0 0; }

        .mode-toggle {
            display: flex;
            background: #f1f5f9;
            padding: 6px;
            border-radius: 16px;
            margin: 32px 0;
        }

        .mode-btn {
            flex: 1; padding: 12px; border: none; background: transparent;
            font-weight: 700; color: var(--text-muted); cursor: pointer;
            border-radius: 12px; font-size: 0.85rem; letter-spacing: 0.05em;
        }

        .mode-btn.active {
            background: var(--white);
            color: var(--dark-green);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; margin-bottom: 8px; color: var(--text-main); font-weight: 700; font-size: 0.85rem; }

        .input-box { position: relative; display: flex; align-items: center; }
        .input-box i { position: absolute; left: 16px; color: var(--text-muted); font-size: 1.1rem; }

        .input-box input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            background: #f8fafc;
            border: 2px solid #f1f5f9;
            border-radius: 14px;
            font-size: 1rem;
            outline: none;
        }

        .input-box input:focus {
            background: var(--white);
            border-color: var(--whatsapp-green);
            box-shadow: 0 0 0 4px rgba(37, 211, 102, 0.1);
        }

        .toggle-password { position: absolute; right: 16px; left: auto !important; cursor: pointer; }

        .btn-submit {
            width: 100%;
            background: var(--primary-gradient);
            color: white; border: none;
            padding: 16px; border-radius: 14px;
            font-size: 1rem; font-weight: 700;
            cursor: pointer; margin-top: 12px;
            display: flex; justify-content: center; align-items: center; gap: 10px;
        }

        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(7, 94, 84, 0.2); }

        .footer-note { text-align: center; margin-top: 24px; font-size: 0.85rem; color: var(--text-muted); }
    </style>
</head>

<body>

    <div class="auth-card">
        <div class="brand-header">
            <div class="logo-circle">
                <i class="fas fa-shield-check" id="main-icon"></i>
            </div>
            <h1 id="title">Portal Login</h1>
            <p id="desc">Secure access to OAS Support systems.</p>
        </div>

        <div class="mode-toggle">
            <button class="mode-btn active" onclick="switchMode('admin')">ADMINISTRATOR</button>
            <button class="mode-btn" onclick="switchMode('member')">TEAM MEMBER</button>
        </div>

        <form id="loginForm">
            <div class="input-group">
                <label id="phone-label">Admin WhatsApp Number</label>
                <div class="input-box">
                    <i class="fab fa-whatsapp"></i>
                    <input id="unumber" type="text" placeholder="923001234567" required>
                </div>
            </div>

            <div class="input-group">
                <label>Secure Password</label>
                <div class="input-box">
                    <i class="far fa-lock-alt"></i>
                    <input id="passl" type="password" placeholder="••••••••" required>
                    <i class="far fa-eye toggle-password" id="togglePass"></i>
                </div>
            </div>

            <button type="button" class="btn-submit" onclick="handleAuth()">
                <span id="btn-text">Sign Into Dashboard</span>
                <i class="fas fa-arrow-right"></i>
            </button>
        </form>

        <div class="footer-note">
            <i class="fas fa-info-circle"></i> Unauthorized access is strictly monitored.
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let currentMode = 'admin';

        // Password Toggle Logic
        document.getElementById("togglePass").addEventListener("click", function() {
            const input = document.getElementById("passl");
            const isPass = input.type === "password";
            input.type = isPass ? "text" : "password";
            this.classList.toggle("fa-eye");
            this.classList.toggle("fa-eye-slash");
        });

        function switchMode(mode) {
            currentMode = mode;
            
            // UI Updates
            document.querySelectorAll('.mode-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            const icon = document.getElementById('main-icon');
            const title = document.getElementById('title');
            const phoneLabel = document.getElementById('phone-label');
            const btnText = document.getElementById('btn-text');

            if (mode === 'member') {
                title.innerText = "Member Access";
                phoneLabel.innerText = "Member WhatsApp Number";
                btnText.innerText = "Member Dashboard";
                icon.className = "fas fa-user-tie";
            } else {
                title.innerText = "Admin Portal";
                phoneLabel.innerText = "Admin WhatsApp Number";
                btnText.innerText = "Admin Dashboard";
                icon.className = "fas fa-shield-check";
            }
        }

        async function handleAuth() {
            const unumber = document.getElementById('unumber');
            const pass = document.getElementById('passl');

            // Native Validation
            if(!unumber.reportValidity()) return;
            if(!pass.reportValidity()) return;

            Swal.fire({
                title: 'Verifying...',
                html: `Authenticating ${currentMode} credentials`,
                didOpen: () => Swal.showLoading()
            });

            // Simplified Payload
            const payload = {
                type: currentMode,
                number: unumber.value,
                password: pass.value
            };

            try {
                const res = await fetch(`/login_check`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Welcome Back!', showConfirmButton: false, timer: 1500 })
                    .then(() => window.location.href = data.redirect);
                } else {
                    Swal.fire('Authentication Failed', data.message, 'error');
                }
            } catch (err) {
                Swal.fire('Connection Error', 'Please check your internet.', 'error');
            }
        }
    </script>
</body>
</html>