<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Team | <%= team.team_name %>
    </title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">

    <style>
        :root {
            --primary: #075e54;
            --whatsapp-green: #25d366;
            --bg: #f8fafc;
            --border: #e2e8f0;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --danger: #ef4444;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            background: white;
            padding: 20px;
            border-radius: 16px;
            border: 1px solid var(--border);
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 30px;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .input-wrapper {
            background: #f1f5f9;
            padding: 12px 18px;
            border-radius: 14px;
            margin-bottom: 20px;
            border: 1px solid transparent;
        }

        .input-wrapper label {
            display: block;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .input-wrapper input {
            width: 100%;
            border: none;
            background: transparent;
            outline: none;
            font-size: 1rem;
            font-weight: 600;
        }

        .agent-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px;
            border-bottom: 1px solid var(--border);
        }

        .agent-info h4 {
            margin: 0;
            font-size: 0.95rem;
        }

        .role-badge {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 800;
            cursor: pointer;
            border: 1px solid var(--border);
            transition: 0.2s;
        }

        .role-badge.is-lead {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .role-badge.is-member {
            background: #f1f5f9;
            color: var(--text-muted);
        }

        .btn-save {
            background: var(--primary);
            color: white;
            padding: 15px 35px;
            border-radius: 12px;
            border: none;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-save:hover {
            background: var(--whatsapp-green);
            transform: translateY(-2px);
        }

        .btn-remove {
            color: var(--danger);
            cursor: pointer;
            border: none;
            background: none;
            margin-left: 15px;
        }
    </style>
</head>

<body>

    <div id="data-all-agents" style="display:none;"
        data-payload='<%- JSON.stringify(typeof all_agents !== "undefined" ? all_agents : []) %>'></div>
    <div id="data-team-info" style="display:none;" data-payload='<%- JSON.stringify(team.agent_info || {}) %>'></div>
    <div id="data-selected-nums" style="display:none;"
        data-payload='<%- JSON.stringify(typeof selected_nums !== "undefined" ? selected_nums : []) %>'></div>

    <div class="container">
        <div class="header">
            <div>
                <a href="javascript:history.back()"
                    style="text-decoration:none; color:var(--text-muted); font-size: 0.8rem;">
                    <i class="fas fa-arrow-left"></i> BACK
                </a>
                <h1 style="margin:5px 0 0 0;">Modify Team: <%= team.team_name %>
                </h1>
            </div>
            <button class="btn-save" onclick="saveTeamChanges()">Save Changes</button>
        </div>

        <div class="grid">
            <div class="card">
                <h3><i class="fas fa-cog"></i> Configuration</h3>
                <div class="input-wrapper">
                    <label>Team Name</label>
                    <input type="text" id="edit_team_name" value="<%= team.team_name %>">
                </div>

                <div class="input-wrapper">
                    <label>Groups</label>
                    <select id="edit_group_input" multiple>
                        <% allgrps.forEach(g=> { %>
                            <option value="<%= g %>" <%=team.groups.includes(g) ? 'selected' : '' %>
                                <%= selected_grps.includes(g) ? 'disabled' : '' %>>
                                    <%= g %>
                            </option>
                            <% }) %>
                    </select>
                </div>
            </div>

            <div class="card">
                <h3><i class="fas fa-user-shield"></i> Agents</h3>

                <div style="margin-bottom: 25px;">
                    <label style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted);">ADD AGENT TO
                        TEAM</label>
                    <select id="add_agent_dropdown"></select>
                </div>

                <div id="active_agents_list">
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let ALL_AGENTS = [];
        let currentAgents = {};
        let GLOBAL_TAKEN_NUMS = [];
        let oldAgents = [];

        // 1. Initialize Data// 1. Initialize Data
        try {
            ALL_AGENTS = JSON.parse(document.getElementById('data-all-agents').getAttribute('data-payload'));
            GLOBAL_TAKEN_NUMS = JSON.parse(document.getElementById('data-selected-nums').getAttribute('data-payload'));
            const initialInfo = JSON.parse(document.getElementById('data-team-info').getAttribute('data-payload'));

            Object.entries(initialInfo).forEach(([decoratedKey, data]) => {
                if (data.number) {
                    // If the key has [number], extract the clean name, otherwise use key as is
                    const cleanName = decoratedKey.includes(' [')
                        ? decoratedKey.split(' [')[0]
                        : decoratedKey;

                    currentAgents[data.number] = {
                        name: cleanName,
                        role: data.role || 'member'
                    };
                }
            });
        } catch (e) { console.error("Initialization Error:", e); }

        // 2. Setup Choices
        const groupChoices = new Choices('#edit_group_input', { removeItemButton: true, searchEnabled: true });
        const agentDropdown = new Choices('#add_agent_dropdown', {
            searchEnabled: true,
            placeholderValue: 'Search name or number...'
        });

        // 3. UI Functions
        function renderAgents() {
            const list = document.getElementById('active_agents_list');
            list.innerHTML = '';

            Object.entries(currentAgents).forEach(([num, data]) => {
                const isLead = data.role === 'lead';
                const div = document.createElement('div');
                div.className = 'agent-item';
                div.innerHTML = `
                <div class="agent-info">
                    <h4>${data.name}</h4>
                    <small style="color:var(--text-muted)">${isLead ? 'TEAM LEADER' : 'MEMBER'} • +${num}</small>
                </div>
                <div style="display:flex; align-items:center;">
                    <div class="role-badge ${isLead ? 'is-lead' : 'is-member'}" onclick="toggleLead('${num}')">
                        ${isLead ? '<i class="fas fa-crown"></i> LEAD' : 'SET AS LEAD'}
                    </div>
                    <button class="btn-remove" onclick="removeAgent('${num}')"><i class="fas fa-trash-alt"></i></button>
                </div>`;
                list.appendChild(div);
            });
            refreshDropdown();
        }

        function refreshDropdown() {
            const choices = ALL_AGENTS.map(agent => {
                const isAlreadyInTeam = currentAgents.hasOwnProperty(agent.number);
                const isTakenByOtherTeam = GLOBAL_TAKEN_NUMS.includes(agent.number);
                return {
                    value: agent.number,
                    label: `${agent.name} (${agent.number})`,
                    selected: false,
                    disabled: isAlreadyInTeam || isTakenByOtherTeam
                };
            });

            agentDropdown.clearChoices();
            agentDropdown.setChoices([
                { value: '', label: 'Add an agent...', disabled: true, selected: true },
                ...choices
            ], 'value', 'label', false);
        }

        function toggleLead(num) {
            if (currentAgents[num].role === 'lead') {
                currentAgents[num].role = 'member';
            } else {
                Object.keys(currentAgents).forEach(k => currentAgents[k].role = 'member');
                currentAgents[num].role = 'lead';
            }
            renderAgents();
        }

        function removeAgent(num) {
            oldAgents.push(num);
            delete currentAgents[num];
            renderAgents();
        }

        document.getElementById('add_agent_dropdown').addEventListener('change', (e) => {
            const num = e.detail.value;
            if (!num) return;

            const agent = ALL_AGENTS.find(a => a.number === num);
            if (agent) {
                currentAgents[num] = { name: agent.name, role: 'member' };
                renderAgents();
                agentDropdown.setChoiceByValue('');
            }
        });

        async function saveTeamChanges() {
            const agent_info_output = {};

            Object.entries(currentAgents).forEach(([num, data]) => {
                // Create a unique key: "Name [Number]"
                // This prevents overwriting when two agents have the same name
                const uniqueKey = `${data.name} [${num}]`;

                agent_info_output[uniqueKey] = {
                    number: num,
                    role: data.role,
                    display_name: data.name // Optional: keep the clean name inside
                };
            });

            const payload = {
                old_name: "<%= team.team_name %>",
                new_name: document.getElementById('edit_team_name').value,
                groups: groupChoices.getValue(true),
                agent_info: agent_info_output,
                oldAgents: oldAgents
            };

            if (!payload.new_name) return Swal.fire('Error', 'Team Name is required', 'error');

            Swal.fire({ title: 'Saving...', didOpen: () => Swal.showLoading() });

            try {
                const res = await fetch('/update-team-full', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.success) {
                    Swal.fire('Saved', 'Team updated with unique keys!', 'success')
                        .then(() => window.location.reload());
                }
            } catch (err) {
                Swal.fire('Error', 'Could not save team', 'error');
            }
        }
        // Initial render
        renderAgents();
    </script>
</body>

</html>